{
  "name": "tauri-explorer",
  "version": "0.2.0",
  "description": "A minimalistic, high-performance file explorer",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest run tests/perf/",
    "bench:render": "vitest run tests/perf/render.bench.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:perf": "playwright test e2e/performance.spec.ts",
    "perf:check": "npx tsx scripts/perf-check.ts",
    "perf:baseline": "npx tsx scripts/perf-check.ts --update",
    "clean": "bash scripts/clean-rebuild.sh",
    "clean:fast": "bash scripts/clean-rebuild.sh --no-rust",
    "start": "bash scripts/dev.sh",
    "start:clean": "bash scripts/dev.sh --clean",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@crabnebula/tauri-plugin-drag": "^2.1.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "tauri-plugin-clipboard-x-api": "^2.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
